{
  "input_directory": "../data/target_data",
  "raw_file_pattern": "*.nc4",
  "variable_name": "CHL",
  "latitude_dim": "latitude",
  "longitude_dim": "longitude",
  "time_dim": "time",
  "study_area_bounds": {
    "latitude_min": -30.0,
    "latitude_max": 30.0,
    "longitude_min": 40.0,
    "longitude_max": 120.0
  },
  "reconstructed_mean_data_file": null,
  "enable_study_area_crop": false,
  "enable_8day_compositing": true,
  "composite_window_size": 8,
  "composite_min_valid_fraction": 0.5,
  "output_directory": "../outputs",
  "preprocessed_data_file": "../data/processed/preprocessed_target_data.nc",
  "enable_regridding": true,
  "target_grid_resolution": 1.0,
  "random_seed": 42,
  "sampled_cell_count": 5,
  "monte_carlo_simulations": 100,
  "ks_pvalue_threshold": 0.05,
  "min_parametric_sample_size": 20,
  "min_positive_variance": 1e-08,
  "min_kde_sample_size": 30,
  "min_kde_unique_values": 2,
  "kde_cv_folds": 3,
  "kde_bandwidth_min": 0.01,
  "kde_bandwidth_max": 10.0,
  "kde_bandwidth_grid_size": 50,
  "positive_distribution_min_value": 0.0,
  "monte_carlo_sample_min_value": 0.0,
  "monte_carlo_summary_percentiles": [
    5,
    25,
    50,
    75,
    95
  ],
  "monte_carlo_preview_sample_count": 20,
  "uncertainty_lower_percentile": 5,
  "uncertainty_upper_percentile": 95,
  "missing_percentage_plot_vmax": 25.0,
  "missing_percentage_plot_tick_step": 5.0,
  "chlorophyll_colorbar_percentile": 98.0,
  "chlorophyll_colorbar_step": 0.05,
  "map_tick_spacing": 10.0,
  "bloom_smoothing_window": 3,
  "bloom_threshold_method": "median_multiplier",
  "bloom_threshold_multiplier": 1.05,
  "bloom_threshold_percentile": 60.0,
  "bloom_detection_year": 2022,
  "save_reconstructed_datasets": false,
  "generate_outputs_and_logs": false,
  "uncertainty_dataset_path": "../outputs/reconstructed/uncertainty_maps.nc",
  "masking_f1_path": "../data/processed/preprocessed_target_data.nc",
  "masking_f2_path": "../data/processed/preprocessed_raw_data.nc",
  "masking_output_path": "../data/processed/masked_validation_dataset.nc",
  "validation_target_data_path": "../data/processed/preprocessed_target_data.nc",
  "validation_input_data_path": "../data/processed/masked_validation_dataset.nc",
  "validation_year": 2018
}