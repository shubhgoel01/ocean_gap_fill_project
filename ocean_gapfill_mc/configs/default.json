{
  "input_directory": "../data/raw",
  "variable_name": "chlor_a",
  "latitude_dim": "lat",
  "longitude_dim": "lon",
  "time_dim": "time",
  "study_area_bounds": {
    "latitude_min": -30.0,
    "latitude_max": 30.0,
    "longitude_min": 40.0,
    "longitude_max": 120.0
  },
  "output_directory": "../outputs",
  "preprocessed_data_file": "../data/processed/tropical_indian_ocean_chlor_a.nc",
  "target_grid_resolution": 1.0,
  "random_seed": 42,
  "sampled_cell_count": 5,
  "monte_carlo_simulations": 100,
  "ks_pvalue_threshold": 0.1,
  "min_parametric_sample_size": 20,
  "min_positive_variance": 1e-8,
  "min_kde_sample_size": 30,
  "min_kde_unique_values": 2,
  "kde_cv_folds": 3,
  "kde_bandwidth_min": 0.01,
  "kde_bandwidth_max": 10.0,
  "kde_bandwidth_grid_size": 50,
  "positive_distribution_min_value": 0.0,
  "monte_carlo_sample_min_value": 0.0,
  "monte_carlo_summary_percentiles": [5, 25, 50, 75, 95],
  "monte_carlo_preview_sample_count": 20,
  "uncertainty_lower_percentile": 5,
  "uncertainty_upper_percentile": 95,
  "missing_percentage_plot_vmax": 25.0,
  "missing_percentage_plot_tick_step": 5.0,
  "chlorophyll_colorbar_percentile": 98.0,
  "chlorophyll_colorbar_step": 0.05,
  "map_tick_spacing": 10.0,
  "save_reconstructed_datasets": true
}
